# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/docs/performance/reports/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local settings
.claude/settings.local.json

# SonarLint local IDE config
.sonarlint/
docs/db-changes-plan.md
docs/frontend-changes-plan.md

# Supabase local config
supabase/*
!supabase/migrations/
!supabase/migrations/*.sql
!supabase/sql/
!supabase/sql/*.sql
supabase/.temp/
